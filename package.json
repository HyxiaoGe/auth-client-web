{
  "name": "auth-client-web",
  "version": "0.1.1",
  "description": "Framework-neutral browser SDK for auth-service: silent SSO via /authorize (PKCE + state), token lifecycle, fetchWithAuth.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "jsdom": "^27.4.0",
    "typescript": "^5",
    "vitest": "^4.0.16"
  }
}
